# Server Configuration
PORT=8082
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=epub_db

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h


USE_AI_CHAPTER_DETECTION=false
USE_CHAPTER_SEGREGATION=false
USE_TOC_EXTRACTION=false

USE_WHISPER_ALIGNMENT=1
# USE_AENEAS_FIRST=1 — Try Aeneas (forced alignment) before Whisper when zone text matches narration
USE_TWO_PASS_ALIGNMENT=1
# BOUNDARY_OVERLAP_SEC=5 — Start each page slice 5s earlier to capture true start (fixes drift)
# SKIP_ALIGNMENT_PAGES=3,4,7 — Comma-separated list of page numbers to exclude from alignment (e.g., if no audio content)
BOUNDARY_OVERLAP_SEC=5
# Suppress Hugging Face symlink warning on Windows (faster-whisper cache)
HF_HUB_DISABLE_SYMLINKS_WARNING=1
USE_SILERO_VAD=1
USE_WHISPERX=0
USE_MFA=1
USE_AENEAS_FIRST=1
SKIP_ALIGNMENT_PAGES=

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800
EPUB_OUTPUT_DIR=epub_output
HTML_INTERMEDIATE_DIR=html_intermediate
TTS_OUTPUT_DIR=uploads/tts_audio

# AI Configuration (Gemini)
GEMINI_API_KEY=AIzaSyAcRFFKbbedcwg_GFZqTLSw3JBUcteo4Y0
GEMINI_API_ENABLED=true
GEMINI_API_MODEL=gemini-2.5-pro
GEMINI_STRUCTURING_MODEL=
GEMINI_TEXT_EXTRACTION=false
GEMINI_VISION_EXTRACTION=true

# OCR Configuration
USE_OCR_EXTRACTION=false
OCR_LANGUAGE=eng
OCR_PSM=6
OCR_DPI=300

# Conversion Pipeline Configuration
USE_TEXT_BASED_PIPELINE=false
TEXT_OVERLAY_VISIBLE=false

# Job Concurrency
MAX_CONCURRENT_JOBS=2

# Rate Limiting (Gemini API)
GEMINI_RATE_LIMIT_PER_MINUTE=50
GEMINI_RATE_LIMIT_PER_HOUR=3000
GEMINI_MIN_INTERVAL_MS=1000

# TTS+SMIL sync: 0.92 = compress 8% (fixes highlight lag). TTS_DURATION_SCALE_FACTOR used at TTS; SMIL used in EPUB.
TTS_DURATION_SCALE_FACTOR=0.92
SMIL_AUDIO_DURATION_FACTOR=0.90

# Google Cloud Text-to-Speech (Optional)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# GCP_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json
# GCP_CREDENTIALS_PATH=/path/to/service-account-key.json
TTS_ENABLED=true

# PNG to XHTML Conversion Flow
USE_PNG_TO_XHTML_FLOW=true

# Fixed-Layout EPUB Mode
USE_FIXED_LAYOUT_EPUB=false
USE_WHISPER_ALIGNMENT=1
USE_TWO_PASS_ALIGNMENT=1
# Whisper: base (fastest), small (better accuracy), medium (best, slow). Use small for 90%+ sync.
WHISPER_MODEL=small
# Set to 1 for faster alignment (uses base+beam_size=1, skips model size from above)
# WHISPER_FAST_ALIGNMENT=1
# Set to 0 to run silence refinement (adds 30-90s ffmpeg step). Default: skip for faster alignment.
# SKIP_SILENCE_SNAPPING=0

# EPUB AI repair: larger OPF + per-file caps (code also enforces full OPF read min)
EPUB_REPAIR_MAX_OPF_INPUT_CHARS=200000
EPUB_REPAIR_MAX_INPUT_CHARS=60000
EPUB_REPAIR_DEBUG=1

PLATFORM_ADMIN_EMAIL=aachalbyline@gmail.com
ALLOW_PUBLIC_REGISTRATION=false
USE_PDF2HTMLEX_FIXED_LAYOUT=true
PDF2HTMLEX_USE_DOCKER=true
PDF2HTMLEX_DOCKER_PATH=C:\Program Files\Docker\Docker\resources\bin\docker.exe